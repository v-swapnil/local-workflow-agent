{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/main/index.ts",
    "src/preload/index.ts",
    "src/renderer/src/main.tsx",
    "electron.vite.config.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}"
  ],
  "paths": {
    "@shared/*": ["src/shared/*"],
    "@main/*": ["src/main/*"],
    "@renderer/*": ["src/renderer/src/*"]
  },
  "ignore": [
    "src/preload/index.d.ts"
  ]
}
